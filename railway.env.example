# === Recomendado: evitar osmium extract (sin descargar Argentina entera) ===
# Subí salta.osm.pbf a Supabase Storage y usá:
# PBF_URL=https://TU_PROYECTO.supabase.co/storage/v1/object/public/osm-data/salta.osm.pbf

# === Arranque normal (grafo ya en /data) ===
FORCE_REBUILD=false
FORCE_REEXTRACT=false

# === Solo si necesitás reconstruir (una vez; luego volver a false) ===
# FORCE_REBUILD=true
# FORCE_REEXTRACT=true
# Scale → Memory: 4 GB mínimo mientras construye
# Deploy → Healthcheck timeout: 3600 s

# PBF Argentina en volumen (evita re-descarga):
# PBF_SOURCE_PATH=/data/argentina-260618.osm.pbf
# KEEP_ARGENTINA_PBF=true
