# Volumen obligatorio montado en /data (2 GB+).

# Arranque normal (grafo ya en volumen):
# FORCE_REBUILD=false

# Reconstruir grafo tras actualizar OSM (solo una vez):
# FORCE_REBUILD=true
# Healthcheck timeout en Railway UI: 2400 segundos (40 min)
# Después del deploy exitoso, volver a FORCE_REBUILD=false

# PBF en volumen (más rápido que descargar Argentina):
# PBF_SOURCE_PATH=/data/argentina-260618.osm.pbf
# KEEP_ARGENTINA_PBF=true

# PBF directo (extract BBBike/Geofabrik de Salta):
# PBF_URL=https://...
