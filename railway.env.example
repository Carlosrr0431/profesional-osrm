# Opcional: desactivar caché HTTP en nginx (por defecto activa)
# CACHE_ENABLED=true

# OSRM: rutas cacheadas 15 min en disco (nginx, volumen /data/nginx-cache)
# Opcional: montar volumen en /data para persistir el grafo entre redeploys.

DATA_DIR=/data
MAP_NAME=salta
SALTA_EXTRACT=true

# PBF en volumen (el entrypoint extrae Salta automáticamente):
# PBF_SOURCE_PATH=/data/argentina-260618.osm.pbf
# IMPORT_REGION=salta
# KEEP_ARGENTINA_PBF=true
